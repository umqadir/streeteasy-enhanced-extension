{
  "manifest_version": 3,
  "name": "SleepEasy",
  "version": "1.0.0",
  "description": "Adds inline NYC crime statistics to StreetEasy listing pages using precompiled NYC Open Data",
  "content_scripts": [
    {
      "matches": [
        "https://streeteasy.com/building/*",
        "https://streeteasy.com/rental/*",
        "https://streeteasy.com/sale/*",
        "https://*.streeteasy.com/building/*",
        "https://*.streeteasy.com/rental/*",
        "https://*.streeteasy.com/sale/*"
      ],
      "js": [
        "lib/geo-utils.js",
        "lib/utils.js",
        "content/coordinates-extractor.js",
        "content/ui-injector.js",
        "content/main.js"
      ],
      "css": [
        "ui/inline-module.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "SleepEasy"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "data/nta-boundaries.json",
        "data/crime-stats.json",
        "data/nta-exposure.json"
      ],
      "matches": [
        "https://streeteasy.com/*",
        "https://*.streeteasy.com/*"
      ]
    }
  ]
}
