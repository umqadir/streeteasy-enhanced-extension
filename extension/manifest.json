{
  "manifest_version": 3,
  "name": "SleepEasy",
  "version": "1.1.0",
  "description": "Adds inline NYC crime statistics and area estimation tools to StreetEasy listing pages",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://streeteasy.com/building/*",
        "https://streeteasy.com/rental/*",
        "https://streeteasy.com/sale/*",
        "https://*.streeteasy.com/building/*",
        "https://*.streeteasy.com/rental/*",
        "https://*.streeteasy.com/sale/*"
      ],
      "js": [
        "lib/geo-utils.js",
        "lib/utils.js",
        "content/coordinates-extractor.js",
        "content/ui-injector.js",
        "content/main.js"
      ],
      "css": [
        "ui/inline-module.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://streeteasy.com/building/*",
        "https://streeteasy.com/rental/*",
        "https://streeteasy.com/sale/*",
        "https://*.streeteasy.com/building/*",
        "https://*.streeteasy.com/rental/*",
        "https://*.streeteasy.com/sale/*"
      ],
      "js": [
        "lib/shared-types.js",
        "content/sqft/listing-context.js",
        "content/sqft/content-bridge.js",
        "content/sqft/photo-overlay.js"
      ],
      "css": [
        "content/sqft/photo-overlay.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "SleepEasy"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "data/nta-boundaries.json",
        "data/crime-stats.json",
        "data/nta-exposure.json"
      ],
      "matches": [
        "https://streeteasy.com/*",
        "https://*.streeteasy.com/*"
      ]
    }
  ]
}
